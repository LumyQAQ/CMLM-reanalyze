# Optional configuration for scripts/cmlm_auto_job.py.
# Copy to scripts/cmlm_auto.env or set CMLM_ENV=/path/to/file.

# CMLM_DIR=/path/to/CMLM-reanalyze
# CMLM_REMOTE_URL=https://github.com/LumyQAQ/CMLM-reanalyze.git
# CMLM_PUBLISH_DIR=/tmp/cmlm_reanalyze_publish_live
# CMLM_DRYRUN_PUBLISH_DIR=/tmp/cmlm_reanalyze_publish_live_dryrun

# Notification provider: pushplus, serverchan, wecom, or leave blank.
# CMLM_NOTIFY_PROVIDER=pushplus
# CMLM_NOTIFY_DRY_RUN=1
# CMLM_NOTIFY_MAX_CHARS=7000

# PUSHPLUS_TOKEN=
# PUSHPLUS_TOPIC=
# SERVERCHAN_SENDKEY=
# WECOM_BOT_WEBHOOK=
